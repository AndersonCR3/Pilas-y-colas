{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar App (javac)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$userProfilePath = $env:USERPROFILE; $cp = \"$userProfilePath\\.m2\\repository\\org\\apache\\logging\\log4j\\log4j-api\\2.17.2\\log4j-api-2.17.2.jar;$userProfilePath\\.m2\\repository\\org\\apache\\logging\\log4j\\log4j-core\\2.17.2\\log4j-core-2.17.2.jar\"; $files = Get-ChildItem -Path src/main/java -Filter *.java -Recurse | ForEach-Object { $_.FullName }; javac -cp $cp -d target/classes $files"
      ],
      "problemMatcher": [
        "$javac"
      ],
      "group": "build"
    }
  ]
}
