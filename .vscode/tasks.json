{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar App (javac)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$files = Get-ChildItem -Path src/main/java -Filter *.java -Recurse | ForEach-Object { $_.FullName }; javac -d target/classes $files"
      ],
      "problemMatcher": [
        "$javac"
      ],
      "group": "build"
    }
  ]
}
